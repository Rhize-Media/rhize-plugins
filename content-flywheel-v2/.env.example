# Neo4j (required)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# DataForSEO (for cron jobs)
DATAFORSEO_USERNAME=
DATAFORSEO_PASSWORD=

# Sanity CMS adapter
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_TOKEN=

# GoHighLevel distribution adapter
GHL_API_KEY=
GHL_LOCATION_ID=

# Firecrawl (site crawling for content discovery)
FIRECRAWL_API_KEY=

# Obsidian MCP (vault research for inspiration)
OBSIDIAN_API_KEY=

# Slack (notifications and approvals)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
